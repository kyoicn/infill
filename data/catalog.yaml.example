# 产品目录示例 — 系统唯一数据源
# 复制为 catalog.yaml 后修改，在网页上点击"重新加载目录"即可生效

组件:
  - 名称: 组件A
    描述: 底座部件
    可选颜色: [白色, 红色, 黑色]
  - 名称: 组件B
    描述: 顶盖部件
    可选颜色: [白色, 黑色]
  - 名称: 组件C
    描述: 通用配件

打印盘:
  - 盘号: 1号盘
    组件: 组件A
    数量: 10
    耗时分钟: 120
  - 盘号: 2号盘
    组件: 组件B
    数量: 8
    耗时分钟: 90
  - 盘号: 3号盘
    组件: 组件C
    数量: 20
    耗时分钟: 60

产品:
  - 名称: 产品A
    描述: 白+黑经典款
    BOM:
      - 组件: 组件A
        颜色: 白色
        数量: 1
      - 组件: 组件B
        颜色: 黑色
        数量: 1
      - 组件: 组件C
        数量: 2
  - 名称: 产品B
    描述: 红+白限定款
    BOM:
      - 组件: 组件A
        颜色: 红色
        数量: 1
      - 组件: 组件B
        颜色: 白色
        数量: 1
      - 组件: 组件C
        数量: 2
